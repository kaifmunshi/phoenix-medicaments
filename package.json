{
  "name": "phoenix-medicaments",
  "version": "0.1.0",
  "private": true,
  "workspaces": [
    "client",
    "server",
    "admin-vue"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server",
    "dev:client": "npm run dev --workspace client",
    "dev:server": "npm run dev --workspace server",
    "dev:admin": "npm run dev --workspace admin-vue",
    "build": "npm run build --workspace client && npm run build --workspace admin-vue",
    "start": "npm run start --workspace server"
  }
}

